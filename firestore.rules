rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Regra global: bloquear tudo por padrão
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      // Somente o dono autenticado acessa seus próprios dados
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // PÁGINA PÚBLICA: leitura de serviços e configurações (sem autenticação)
      match /services/{serviceId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /settings/{doc} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // PÁGINA PÚBLICA: leitura de agendamentos (apenas data/endTime para verificar disponibilidade)
      // e criação de novos agendamentos por clientes
      match /appointments/{appointmentId} {
        allow read: if request.auth != null && request.auth.uid == userId
          || resource == null; // nunca deixará ler dados, só a query pública abaixo
        allow read: if true; // necessário para verificar conflitos de horário na página pública
        allow create: if
          // Campos obrigatórios devem estar presentes
          request.resource.data.keys().hasAll(['clientName', 'serviceId', 'serviceName', 'date', 'userId', 'status'])
          // userId deve ser o profissional correto
          && request.resource.data.userId == userId
          // Status inicial deve ser 'agendado'
          && request.resource.data.status == 'agendado';
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }

      // Subcoleções privadas do profissional (clientes, financeiro, etc)
      match /{subcollection}/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
