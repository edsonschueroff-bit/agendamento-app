rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function professionalLinkPath() {
      return /databases/$(database)/documents/professionalLinks/$(request.auth.uid);
    }

    function isLinkedProfessionalOf(ownerId) {
      return isAuthenticated()
        && exists(professionalLinkPath())
        && get(professionalLinkPath()).data.ownerId == ownerId;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /professionalLinks/{professionalId} {
      allow read: if isAuthenticated() && request.auth.uid == professionalId;
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /services/{serviceId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      match /settings/business {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      match /settings/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /appointments/{appointmentId} {
        allow read: if isOwner(userId) || isLinkedProfessionalOf(userId);

        allow create: if
          request.resource.data.keys().hasAll([
            'clientName',
            'serviceId',
            'serviceName',
            'date',
            'userId',
            'status'
          ]) &&
          request.resource.data.userId == userId &&
          request.resource.data.status == 'agendado' &&
          (
            !request.resource.data.keys().hasAny(['reschedulingToken']) ||
            request.resource.data.reschedulingToken is string
          ) &&
          (
            !request.resource.data.keys().hasAny(['reschedulingExpiresAt']) ||
            request.resource.data.reschedulingExpiresAt is timestamp
          );

        allow update, delete: if isOwner(userId);
      }

      match /professionals/{professionalId} {
        allow read: if isOwner(userId)
          || (isAuthenticated() && request.auth.uid == professionalId && isLinkedProfessionalOf(userId));
        allow write: if isOwner(userId);

        match /commissions/{commissionId} {
          allow read: if isOwner(userId)
            || (isAuthenticated() && request.auth.uid == professionalId && isLinkedProfessionalOf(userId));
          allow write: if isOwner(userId);
        }
      }

      match /{subcollection}/{document=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}

